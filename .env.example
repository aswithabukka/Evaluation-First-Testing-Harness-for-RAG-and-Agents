# Copy to .env and fill in values

# ── LLM provider ────────────────────────────────────────────────────────────
# You need EITHER an OpenAI key OR an OpenRouter key. OpenRouter unlocks
# cheaper open-source judges (DeepSeek V3, Qwen 3, Kimi K2, QwQ-32B) through
# the same OpenAI-compatible API — recommended for high-volume eval runs.
#
# If only OPENROUTER_API_KEY is set, the harness auto-routes through
# OpenRouter. If both are set, LLM_PROVIDER disambiguates.

OPENAI_API_KEY=sk-...

# OpenRouter: get a key at https://openrouter.ai/keys — pay-as-you-go,
# ~$0.14/M tokens for DeepSeek V3 vs. ~$2.50/M tokens for GPT-4o.
OPENROUTER_API_KEY=
# OPENROUTER_BASE_URL=https://openrouter.ai/api/v1    # override if self-hosted

# Force a provider when both keys are set. Values: openai | openrouter
LLM_PROVIDER=

# Default judge model. State-of-the-art OpenRouter picks (April 2026):
#   qwen/qwen3.6-plus                     — BEST VALUE, 1M context, $0.33/$1.95
#   deepseek/deepseek-v3.2                — CHEAPEST strong judge, $0.25/$0.38
#   moonshotai/kimi-k2.6                  — long-answer specialist, 262k, $0.60/$2.80
#   qwen/qwen3-max-thinking               — reasoning variant for g_eval, $0.78/$3.90
#   qwen/qwen3-235b-a22b-thinking-2507    — cheapest reasoning, $0.13/$0.60
#   moonshotai/kimi-k2-thinking           — Kimi reasoning, 262k, $0.60/$2.50
#   qwen/qwen3.5-397b-a17b                — MoE flagship, $0.39/$2.34
#   z-ai/glm-5                            — new strong contender, $0.65/$2.08
#   anthropic/claude-opus-4.7             — calibration gold baseline, $5/$25
#   anthropic/claude-sonnet-4.6           — calibration fast baseline, $3/$15
#   openai/gpt-5.4                        — OpenAI frontier via OpenRouter, $2.50/$15
#   gpt-5.4                               — OpenAI direct (requires OPENAI_API_KEY)
LLM_DEFAULT_MODEL=

# Database (used by API and Celery worker)
DATABASE_URL=postgresql+asyncpg://postgres:postgres@db:5432/rageval
SYNC_DATABASE_URL=postgresql://postgres:postgres@db:5432/rageval

# Redis
REDIS_URL=redis://redis:6379/0
CELERY_BROKER_URL=redis://redis:6379/1
CELERY_RESULT_BACKEND=redis://redis:6379/2

# Optional: GitHub integration for release gate status checks
GITHUB_TOKEN=ghp_...

# Optional: Override default thresholds
DEFAULT_FAITHFULNESS_THRESHOLD=0.7
DEFAULT_ANSWER_RELEVANCY_THRESHOLD=0.7
DEFAULT_CONTEXT_PRECISION_THRESHOLD=0.6
DEFAULT_CONTEXT_RECALL_THRESHOLD=0.6
DEFAULT_PASS_RATE_THRESHOLD=0.8

# ── Production Features ────────────────────────────────────

# API key authentication (comma-separated list; empty = auth disabled)
API_KEYS=

# CORS allowed origins (comma-separated; * = allow all)
CORS_ORIGINS=*

# Production traffic sampling rates
SAMPLING_RATE=0.2
SAMPLING_ERROR_RATE=1.0

# Alerting — Slack/Teams webhook URL for threshold breach notifications
ALERT_WEBHOOK_URL=

 #Web search — Serper API (Google search) for playground Search Engine
# Get a free API key at https://serper.dev (2500 free searches)
SERPER_API_KEY= 